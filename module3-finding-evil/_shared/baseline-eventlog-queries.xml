<!--
  Windows Event Log XML Query Reference
  Case: DESKTOP-NU10MTO Investigation
  Machine Timezone: UTC-7
  Sysmon Channel: Microsoft-Windows-Sysmon/Operational

  TIMESTAMP RULE: SystemTime in logs is always UTC.
  Convert local time using the offset from the machine's own events,
  NOT from the analyst machine. Compare display time vs raw SystemTime
  in the Event XML tab to get the true offset.
-->

<!-- ============================================================
  QUERY 1 — Event ID 4624 Basic (All Successful Logons)
  Reason: Starting point for logon investigation. Returns every
  successful logon in the Security log. Used to confirm the log
  is loaded and results are returning before adding time filters.
  Log: Security
============================================================ -->
<QueryList>
  <Query Id="0" Path="Security">
    <Select Path="Security">
      *[System[(EventID=4624)]]
    </Select>
  </Query>
</QueryList>


<!-- ============================================================
  QUERY 2 — Event ID 4624 at Exact Timestamp
  Reason: Isolate a specific logon event at 8/3/2022 10:23:25 AM
  local (UTC-7). UTC offset derived from the machine's own event:
  display 9:50:37 AM vs SystemTime 16:50:37Z = UTC-7.
  10:23:25 AM local + 7h = 17:23:25Z UTC.
  Use 1-second window because SystemTime includes milliseconds
  (e.g. 17:23:25.546Z) so an exact-second match would miss it.
  Log: Security
============================================================ -->
<QueryList>
  <Query Id="0" Path="Security">
    <Select Path="Security">
      *[System[
        (EventID=4624)
        and
        (TimeCreated[
          @SystemTime &gt;= '2022-08-03T17:23:25.000000000Z'
          and
          @SystemTime &lt;= '2022-08-03T17:23:25.999999999Z'
        ])
      ]]
    </Select>
  </Query>
</QueryList>


<!-- ============================================================
  QUERY 3 — Event ID 4907 Full Day (Auditing Settings Changes)
  Reason: Find the executable that modified auditing settings on
  8/3/2022. Event 4624 at 10:23:25 was the entry point; 4907
  records SACL changes and includes ProcessName (full exe path).
  Broad day window used first to discover all 4907 events before
  narrowing. Full day 8/3/2022 UTC-7 = 07:00Z to next 07:00Z.
  Result: TiWorker.exe modified SACL on wpfgfx_v0400.dll.
  Log: Security
============================================================ -->
<QueryList>
  <Query Id="0" Path="Security">
    <Select Path="Security">
      *[System[
        (EventID=4907)
        and
        (TimeCreated[
          @SystemTime &gt;= '2022-08-03T07:00:00.000000000Z'
          and
          @SystemTime &lt;= '2022-08-04T06:59:59.999999999Z'
        ])
      ]]
    </Select>
  </Query>
</QueryList>


<!-- ============================================================
  QUERY 4 — Event ID 4907 Scoped to Specific Object + Process
  Reason: Confirm TiWorker.exe (Windows Update servicing worker)
  was the executable that changed the SACL on wpfgfx_v0400.dll.
  Combined ObjectName + ProcessName pins the exact modification.
  Finding: Normal Windows Update behavior — TiWorker running as
  SYSTEM added an audit ACE (AU;SAFA;DCLCRPCRSDWDWO;;;WD) meaning
  log success+failure for Everyone on delete/modify/owner rights.
  Log: Security
============================================================ -->
<QueryList>
  <Query Id="0" Path="Security">
    <Select Path="Security">
      *[System[(EventID=4907)]]
      and
      *[EventData[Data[@Name='ObjectName']='C:\Windows\Microsoft.NET\Framework64\v4.0.30319\WPF\wpfgfx_v0400.dll']]
      and
      *[EventData[Data[@Name='ProcessName']='C:\Windows\WinSxS\amd64_microsoft-windows-servicingstack_31bf3856ad364e35_10.0.19041.1790_none_7df2aec07ca10e81\TiWorker.exe']]
    </Select>
  </Query>
</QueryList>


<!-- ============================================================
  QUERY 5 — Sysmon Event ID 7 Unsigned DLLs
  Reason: Hunt for malicious DLL loads. Legitimate system DLLs
  are always Microsoft-signed. Signed=false means the DLL has no
  valid signature — strong IOC for DLL hijacking or a dropped
  malicious DLL. Cannot use != operator (XPath trap: evaluates
  true if ANY data node differs, returning garbage results).
  Signed field is a string "true"/"false" not a boolean.
  Log: Microsoft-Windows-Sysmon/Operational
============================================================ -->
<QueryList>
  <Query Id="0" Path="Microsoft-Windows-Sysmon/Operational">
    <Select Path="Microsoft-Windows-Sysmon/Operational">
      *[System[(EventID=7)]]
      and
      *[EventData[Data[@Name='Signed']='false']]
    </Select>
  </Query>
</QueryList>


<!-- ============================================================
  QUERY 6 — Sysmon Event ID 7 Signed But Not Microsoft
  Reason: Catches DLLs that ARE signed but not by Microsoft —
  e.g. attacker-signed or third-party malicious DLLs that would
  pass the Signed=false check. Uses <Suppress> instead of !=
  to exclude known Microsoft signer strings. Suppression wins
  over Select when both match the same event.
  Log: Microsoft-Windows-Sysmon/Operational
============================================================ -->
<QueryList>
  <Query Id="0" Path="Microsoft-Windows-Sysmon/Operational">
    <Select Path="Microsoft-Windows-Sysmon/Operational">
      *[System[(EventID=7)]]
    </Select>
    <Suppress Path="Microsoft-Windows-Sysmon/Operational">
      *[EventData[Data[@Name='Signature']='Microsoft Corporation']]
    </Suppress>
    <Suppress Path="Microsoft-Windows-Sysmon/Operational">
      *[EventData[Data[@Name='Signature']='Microsoft Windows']]
    </Suppress>
    <Suppress Path="Microsoft-Windows-Sysmon/Operational">
      *[EventData[Data[@Name='Signature']='Microsoft Windows Publisher']]
    </Suppress>
  </Query>
</QueryList>


<!-- ============================================================
  QUERY 7 — Sysmon Event ID 7 clr.dll / clrjit.dll Loads (Broad)
  Reason: Detect execute-assembly or unmanaged PowerShell injection
  attacks. clr.dll (Common Language Runtime) and clrjit.dll (CLR
  JIT compiler) only load in .NET-based processes. If observed in
  processes that do not normally run .NET code (notepad, calc,
  svchost, rundll32 etc.) it indicates malicious CLR injection.
  This query returns ALL processes loading these DLLs so you can
  identify which Image values are unexpected before suppressing.
  Both x64 (Framework64) and x86 (Framework) paths covered.
  Log: Microsoft-Windows-Sysmon/Operational
============================================================ -->
<QueryList>
  <Query Id="0" Path="Microsoft-Windows-Sysmon/Operational">
    <Select Path="Microsoft-Windows-Sysmon/Operational">
      *[System[(EventID=7)]]
      and
      *[EventData[
        Data[@Name='ImageLoaded']='C:\Windows\Microsoft.NET\Framework64\v4.0.30319\clr.dll'
        or
        Data[@Name='ImageLoaded']='C:\Windows\Microsoft.NET\Framework\v4.0.30319\clr.dll'
        or
        Data[@Name='ImageLoaded']='C:\Windows\Microsoft.NET\Framework64\v4.0.30319\clrjit.dll'
        or
        Data[@Name='ImageLoaded']='C:\Windows\Microsoft.NET\Framework\v4.0.30319\clrjit.dll'
      ]]
    </Select>
  </Query>
</QueryList>


<!-- ============================================================
  QUERY 8 — Sysmon Event ID 7 clr.dll / clrjit.dll (Filtered)
  Reason: Same as Query 7 but with known-legitimate .NET host
  processes suppressed. What remains after suppression are
  processes that have NO business loading the .NET runtime —
  the IOC for execute-assembly / unmanaged PowerShell injection.
  Add further <Suppress> entries for any additional legitimate
  .NET processes found in your environment (devenv.exe, msbuild
  etc.) to reduce noise specific to this machine.
  Log: Microsoft-Windows-Sysmon/Operational
============================================================ -->
<QueryList>
  <Query Id="0" Path="Microsoft-Windows-Sysmon/Operational">
    <Select Path="Microsoft-Windows-Sysmon/Operational">
      *[System[(EventID=7)]]
      and
      *[EventData[
        Data[@Name='ImageLoaded']='C:\Windows\Microsoft.NET\Framework64\v4.0.30319\clr.dll'
        or
        Data[@Name='ImageLoaded']='C:\Windows\Microsoft.NET\Framework\v4.0.30319\clr.dll'
        or
        Data[@Name='ImageLoaded']='C:\Windows\Microsoft.NET\Framework64\v4.0.30319\clrjit.dll'
        or
        Data[@Name='ImageLoaded']='C:\Windows\Microsoft.NET\Framework\v4.0.30319\clrjit.dll'
      ]]
    </Select>
    <!-- Suppress known legitimate .NET host processes -->
    <Suppress Path="Microsoft-Windows-Sysmon/Operational">
      *[EventData[Data[@Name='Image']='C:\Windows\System32\WindowsPowerShell\v1.0\powershell.exe']]
    </Suppress>
    <Suppress Path="Microsoft-Windows-Sysmon/Operational">
      *[EventData[Data[@Name='Image']='C:\Windows\SysWOW64\WindowsPowerShell\v1.0\powershell.exe']]
    </Suppress>
    <Suppress Path="Microsoft-Windows-Sysmon/Operational">
      *[EventData[Data[@Name='Image']='C:\Windows\System32\WindowsPowerShell\v1.0\powershell_ise.exe']]
    </Suppress>
    <Suppress Path="Microsoft-Windows-Sysmon/Operational">
      *[EventData[Data[@Name='Image']='C:\Windows\Microsoft.NET\Framework64\v4.0.30319\csc.exe']]
    </Suppress>
  </Query>
</QueryList>
